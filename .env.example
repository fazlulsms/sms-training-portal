# ─────────────────────────────────────────────────────────────
# OpenAI / AI Foundation
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=                      # sk-...  Never commit a real key
OPENAI_MODEL=gpt-4o-mini             # gpt-4o-mini | gpt-4o | gpt-4-turbo
OPENAI_TIMEOUT=30                    # HTTP timeout in seconds

AI_FEATURE_ENABLED=false             # Master on/off switch
AI_DAILY_REQUEST_LIMIT=100           # Max API calls per day (across all users)
AI_MONTHLY_BUDGET_USD=10.00          # Soft budget cap — logged, not enforced hard
